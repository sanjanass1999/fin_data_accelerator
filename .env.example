# --- LLM provider keys (all optional; platform falls back gracefully) ---
GROQ_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Provider routing ---
# primary | fallback | embedding can each be: groq | gemini | ollama | simulation
LLM_PRIMARY_PROVIDER=groq
LLM_FALLBACK_PROVIDER=simulation
LLM_EMBEDDING_PROVIDER=local

# --- Model names ---
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_MODEL=phi3
GEMINI_MODEL=gemini-1.5-flash
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Vector store ---
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=findata_financial_docs

# --- Retrieval tuning ---
RETRIEVAL_TOP_K=6
RETRIEVAL_MMR_LAMBDA=0.6
RETRIEVAL_MIN_SCORE=0.20

# --- MCP / data sources ---
MCP_ALLOWED_FS_ROOT=./data
S3_BUCKET=enterprise-financial-docs-prod
POSTGRES_URL=postgresql://findata:findata@localhost:5432/findata

# --- Prefect ---
PREFECT_API_URL=http://prefect_server:4200/api
